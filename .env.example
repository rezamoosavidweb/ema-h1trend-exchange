# ============================================================
# EMA H1 Trend — Bybit Exchange Bot  |  Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Bybit credentials (REQUIRED) ────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Use testnet for testing before going live
BYBIT_TESTNET=false

# ── Symbol ───────────────────────────────────────────────────
# Bybit linear perpetual symbol (USDT-margined)
SYMBOL=BTCUSDT

# ── Strategy parameters ──────────────────────────────────────
# These MUST match the MT5 values for signal parity
RISK_PER_TRADE=0.01        # 1% risk per trade
LEVERAGE=1                 # Leverage multiplier (1x = no leverage)
RR=1.0                     # TP:SL = 1:1

# Optional overrides (auto-detected from symbol if blank)
# PIP_SIZE=1.0             # BTC=1.0, ETH=0.01, etc.
# MAGIC=20260510            # Auto-derived from symbol if blank

# Advanced (leave defaults unless you know what you're doing)
LOOKBACK_BARS=5
PENDING_OFFSET_TICKS=3.0
PENDING_EXPIRY_MIN=60
ENTRY_TF_MINUTES=5

# ── Execution ─────────────────────────────────────────────────
DRY_RUN=false              # true = log signals only, no real orders
POSITION_MODE=one_way      # one_way | hedge
REPLACE_PENDING=false      # Cancel existing pending before placing new

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false             # true = JSON log lines (for Loki/ELK/Datadog)
# LOG_FILE=logs/bot.log    # Uncomment to also write to file

# ── Signal audit log ──────────────────────────────────────────
# SIGNAL_LOG_CSV=logs/signals.csv   # Append strategy signals to CSV

# ── Data fetch sizes ──────────────────────────────────────────
# BARS_ENTRY=600            # M5 bars (includes 200-bar EMA warmup)
# BARS_TREND=350            # H1 bars (includes 200-bar EMA warmup)
