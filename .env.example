# ============================================================
# EMA H1 Trend — Bybit Exchange Bot  |  Environment Variables
# ============================================================
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to version control (it is in .gitignore)

# ── Bybit credentials (REQUIRED) ─────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# true  = Bybit Testnet  (paper trading, testnet.bybit.com)
# false = Live or Demo account
BYBIT_TESTNET=false

# true  = Bybit Demo Trading (api-demo.bybit.com) — real market data, fake money
# false = Live account
BYBIT_DEMO=false

# ── Symbol ───────────────────────────────────────────────────
# Bybit linear perpetual symbol (USDT-margined)
# Examples: BTCUSDT  ETHUSDT  XRPUSDT  SOLUSDT
SYMBOL=BTCUSDT

# ── Position Sizing ──────────────────────────────────────────
#
# Model: margin-based
#
#   margin  = balance × RISK_PER_TRADE
#   qty     = (margin × LEVERAGE) / entry_price
#
# Examples (balance = 1000 USDT):
#
#   Symbol    Entry   Risk  Lev   Margin used   Qty
#   BTCUSDT   80000   1%    1x    10 USDT        0.000125 BTC
#   BTCUSDT   80000   1%    5x    10 USDT        0.000625 BTC
#   ETHUSDT    2500   1%    1x    10 USDT        0.004    ETH
#   XRPUSDT    1.50   2%    10x   20 USDT        133.33   XRP
#
# The margin committed is always (balance × RISK_PER_TRADE) — leverage
# scales position size but does NOT increase the capital at risk from margin.
#
RISK_PER_TRADE=0.01        # Fraction of wallet used as margin per trade (0.01 = 1%)
LEVERAGE=1                 # Position size multiplier (1 = no leverage)

# ── Strategy parameters ──────────────────────────────────────
RR=1.0                     # TP:SL distance ratio (1.0 = 1:1)
LOOKBACK_BARS=5            # Bars in the swing window (HH/LL lookback)
PENDING_OFFSET_TICKS=3.0   # Ticks beyond swing boundary for entry price
PENDING_EXPIRY_MIN=60      # Cancel pending order after N minutes
ENTRY_TF_MINUTES=5         # Entry timeframe in minutes (do not change unless you change TF)

# Optional overrides — auto-detected from symbol name if left blank
# PIP_SIZE=1.0             # BTC=1.0  ETH=0.01  XRP=0.0001  (default: auto)
# MAGIC=12345678           # Order isolation ID (default: auto-derived from symbol)

# ── Execution ─────────────────────────────────────────────────
DRY_RUN=false              # true = log signals only, no real orders placed
POSITION_MODE=one_way      # one_way | hedge
REPLACE_PENDING=false      # true = cancel existing pending before placing new one each cycle

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false             # true = JSON log lines (for Loki / ELK / Datadog)
# LOG_FILE=logs/bot.log    # Uncomment to write structured logs to a file

# ── Signal audit log ──────────────────────────────────────────
# Appends one CSV row per signal the strategy generates (optional)
# SIGNAL_LOG_CSV=logs/signals.csv

# ── Data fetch sizes ──────────────────────────────────────────
# Increase if you see "insufficient warmup bars" warnings
# BARS_ENTRY=600            # M5 bars to fetch (includes 200-bar EMA warmup)
# BARS_TREND=350            # H1 bars to fetch (includes 200-bar EMA warmup)

# ── Telegram Notifications (Telethon — sends as YOUR account) ─
# Get API_ID and API_HASH from https://my.telegram.org/apps
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
#
# Your phone number — if not set, you will be prompted at startup:
# TELEGRAM_PHONE=+989123456789
#
# Path for the Telethon session file (no .session suffix):
# TELEGRAM_SESSION_FILE=telegram_session
#
# Chat/channel ID to send trade notifications to:
# TELEGRAM_CHAT_ID=-1002383929199
#
# Chat ID to listen for slash commands (None = respond to all incoming messages):
# TELEGRAM_LISTEN_CHAT=-1002383929199
